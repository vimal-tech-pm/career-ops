# Portal Scanner Configuration
# Used by /career-ops scan to discover new offers automatically.
#
# Strategy (3 levels):
#   1. Playwright → careers_url of each company (real-time, reliable)
#   2. Greenhouse API → structured JSON (fast, Greenhouse-only)
#   3. WebSearch with site: filters (broad discovery, may be stale)
#
# IMPORTANT: Each company in tracked_companies MUST have careers_url.
#
# HOW TO CUSTOMIZE:
#   1. Copy this file to portals.yml in the project root
#   2. Edit title_filter.positive with YOUR target role keywords
#   3. Add/remove companies in tracked_companies
#   4. Adjust search_queries for your preferred job boards
#   5. Set enabled: false on companies you don't care about

# -- Title filter --
# The scanner uses these keywords to decide if a title is relevant.
# At least 1 positive must match AND 0 negatives must match (case-insensitive).

title_filter:
  positive:
    # [CUSTOMIZE] Product roles aligned to the current target search
    - "Senior Product Manager"
    - "Product Manager"
    - "AI Product Manager"
    - "Technical Product Manager"
    - "Platform Product Manager"
    - "Product Owner"
  negative:
    # [CUSTOMIZE] Exclude adjacent roles that add noise to the scan
    - "Junior"
    - "Intern"
    - "Associate Product Manager"
    - "APM"
    - "Project Manager"
    - "Program Manager"
    - "Scrum Master"
    - "Business Analyst"
    - "Product Designer"
    - "UX"
    - "UI"
    - "Marketing"
    - "Growth Marketing"
    - "Sales"
    - "Customer Success"
    - "Account Manager"
  seniority_boost:
    # These prefixes add relevance but are not required
    - "Senior"
    - "Lead"
    - "Principal"

# -- Search queries --
# Each query triggers a WebSearch. Use site: to filter by portal.
# The scanner extracts title, URL, and company from results.

search_queries:
  # -- Ashby --
  - name: Ashby — Senior Product Remote
    query: 'site:jobs.ashbyhq.com "Senior Product Manager" OR "Technical Product Manager" OR "Platform Product Manager" remote'
    enabled: true

  - name: Ashby — Product Manager Remote
    query: 'site:jobs.ashbyhq.com "Product Manager" remote'
    enabled: true

  - name: Ashby — AI Product Remote
    query: 'site:jobs.ashbyhq.com "AI Product Manager" OR "Generative AI Product Manager" OR "Product Manager" AI remote'
    enabled: true

  - name: Ashby — Product Toronto
    query: 'site:jobs.ashbyhq.com "Product Manager" Toronto'
    enabled: true

  - name: Ashby — Product Canada
    query: 'site:jobs.ashbyhq.com "Product Manager" Canada'
    enabled: true

  # -- Greenhouse --
  - name: Greenhouse — Senior Product Remote
    query: 'site:boards.greenhouse.io OR site:job-boards.greenhouse.io "Senior Product Manager" OR "Technical Product Manager" OR "Platform Product Manager" remote'
    enabled: true

  - name: Greenhouse — Product Manager Remote
    query: 'site:boards.greenhouse.io OR site:job-boards.greenhouse.io "Product Manager" remote'
    enabled: true

  - name: Greenhouse — AI Product Remote
    query: 'site:boards.greenhouse.io OR site:job-boards.greenhouse.io "AI Product Manager" OR "Generative AI Product Manager" OR "Product Manager" AI remote'
    enabled: true

  - name: Greenhouse — Product Toronto
    query: 'site:boards.greenhouse.io OR site:job-boards.greenhouse.io "Product Manager" Toronto'
    enabled: true

  - name: Greenhouse — Product Canada
    query: 'site:boards.greenhouse.io OR site:job-boards.greenhouse.io "Product Manager" Canada'
    enabled: true

  # -- Lever --
  - name: Lever — Senior Product Remote
    query: 'site:jobs.lever.co "Senior Product Manager" OR "Technical Product Manager" OR "Platform Product Manager" remote'
    enabled: true

  - name: Lever — Product Manager Remote
    query: 'site:jobs.lever.co "Product Manager" remote'
    enabled: true

  - name: Lever — AI Product Remote
    query: 'site:jobs.lever.co "AI Product Manager" OR "Generative AI Product Manager" OR "Product Manager" AI remote'
    enabled: true

  - name: Lever — Product Toronto
    query: 'site:jobs.lever.co "Product Manager" Toronto'
    enabled: true

  - name: Lever — Product Canada
    query: 'site:jobs.lever.co "Product Manager" Canada'
    enabled: true

  # -- Long-tail direct boards --
  - name: Wellfound — Startup Product Remote
    query: 'site:wellfound.com "Senior Product Manager" OR "AI Product Manager" OR "Product Manager" remote'
    enabled: true

  - name: Workable — Product Canada/Remote
    query: 'site:apply.workable.com "Senior Product Manager" OR "AI Product Manager" OR "Product Manager" Canada OR remote'
    enabled: true

  # -- Aggregators: enabled but lower-priority --
  - name: LinkedIn — Senior Product NA
    query: 'site:linkedin.com/jobs/view "Senior Product Manager" OR "Technical Product Manager" OR "Platform Product Manager" remote OR Toronto OR Canada'
    enabled: true

  - name: LinkedIn — Product Manager NA
    query: 'site:linkedin.com/jobs/view "Product Manager" remote OR Toronto OR Canada'
    enabled: true

  - name: LinkedIn — AI Product NA
    query: 'site:linkedin.com/jobs/view "AI Product Manager" OR "Generative AI Product Manager" OR "Product Manager" AI remote OR Toronto OR Canada'
    enabled: true

  - name: Indeed — Senior Product NA
    query: 'site:indeed.com/viewjob OR site:ca.indeed.com/viewjob "Senior Product Manager" OR "Technical Product Manager" OR "Platform Product Manager" remote OR Toronto OR Canada'
    enabled: true

  - name: Indeed — Product Manager NA
    query: 'site:indeed.com/viewjob OR site:ca.indeed.com/viewjob "Product Manager" remote OR Toronto OR Canada'
    enabled: true

  - name: Indeed — AI Product NA
    query: 'site:indeed.com/viewjob OR site:ca.indeed.com/viewjob "AI Product Manager" OR "Generative AI Product Manager" OR "Product Manager" AI remote OR Toronto OR Canada'
    enabled: true

  # -- Fintech PM queries --
  - name: Ashby — Fintech Product
    query: 'site:jobs.ashbyhq.com "Product Manager" fintech OR lending OR payments OR banking'
    enabled: true

  - name: Greenhouse — Fintech Product
    query: 'site:boards.greenhouse.io OR site:job-boards.greenhouse.io "Product Manager" fintech OR lending OR payments OR banking'
    enabled: true

  - name: Lever — Fintech Product
    query: 'site:jobs.lever.co "Product Manager" fintech OR lending OR payments OR banking'
    enabled: true

  # -- Enterprise Platform PM queries --
  - name: LinkedIn — Platform Product Manager Canada
    query: 'site:linkedin.com/jobs/view "Platform Product Manager" OR "Senior Product Manager" Toronto OR Canada'
    enabled: true

  # -- Workday boards (banks use Workday ATS) --
  - name: Workday — Product Manager Canada
    query: 'site:myworkdayjobs.com "Product Manager" OR "Senior Product Manager" Canada OR Toronto'
    enabled: true

  # -- Product Owner (cross-portal) --
  - name: Cross-Portal — Product Owner Canada
    query: '"Product Owner" site:jobs.ashbyhq.com OR site:job-boards.greenhouse.io OR site:jobs.lever.co Toronto OR Canada'
    enabled: true

